{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",

    "target": "ES2020",
    "module": "CommonJS",
    "types": ["node"],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
