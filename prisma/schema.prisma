model products {
  id            String   @id @default(uuid()) @db.Uuid
  brandId       String   @db.Uuid
  categoryId    String   @db.Uuid
  name          String
  description   String?
  slug          String   @unique
  viewsCount    BigInt   @default(0)
  ratingAverage Decimal  @default("0.00") @db.Decimal(3, 2)
  ratingCount   Int      @default(0)
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brand             brands               @relation(fields: [brandId], references: [id])
  category          categories           @relation(fields: [categoryId], references: [id])
  // categories categories[]
  variants          products_variants[]
  productSpecifications product_specifications[]
  productHighlights     product_highlights[]

}

model attributes {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options attributes_options[]
}

model attributes_options {
  id          String   @id @default(uuid()) @db.Uuid
  attributeId String   @db.Uuid
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attribute    attributes            @relation(fields: [attributeId], references: [id])
  variantAttrs variants_attributes[]
  @@unique([attributeId, value])
}

model products_variants {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  code      String?  @unique // SKU
  price     Decimal  @db.Decimal(10, 2)
  soldCount Int      @default(0)
  weight    Decimal? @db.Decimal(10, 2) // gram/kg
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product           products                 @relation(fields: [productId], references: [id])
  variantAttributes variants_attributes[]
  images            product_variant_images[]
  inventory         inventory?
  cartItems         cart_items[]
  orderItems        order_items[]
  wishlist          wishlist[]
  voucherActions    voucher_actions[]
}

model variants_attributes {
  id                String   @id @default(uuid()) @db.Uuid
  productVariantId  String   @db.Uuid
  attributeOptionId String   @db.Uuid
  createdAt         DateTime @default(now())

  productVariant  products_variants  @relation(fields: [productVariantId], references: [id])
  attributeOption attributes_options @relation(fields: [attributeOptionId], references: [id])

  @@unique([productVariantId, attributeOptionId])
}

model product_variant_images {
  id               String   @id @default(uuid()) @db.Uuid
  productVariantId String   @db.Uuid
  imageUrl         String
  altText          String?
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productVariant products_variants @relation(fields: [productVariantId], references: [id])
}

model inventory {
  variantId        String   @id @db.Uuid
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0)
  updatedAt        DateTime @updatedAt

  variant products_variants @relation(fields: [variantId], references: [id])
}

model specifications {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique   // chip, ram, battery
  name      String             // Chip, RAM, Pin
  unit      String?            // GB, mAh, inch
  icon      String?
  createdAt DateTime @default(now())

  productSpecifications product_specifications[]
  productHighlights product_highlights[]
}

model product_specifications {
  productId        String @db.Uuid
  specificationId  String @db.Uuid
  value            String
  sortOrder        Int     @default(0)

  product        products        @relation(fields: [productId], references: [id])
  specification  specifications  @relation(fields: [specificationId], references: [id])

  @@id([productId, specificationId])
}

model product_highlights {
  productId        String @db.Uuid
  specificationId  String @db.Uuid
  sortOrder        Int    @default(0)

  product       products        @relation(fields: [productId], references: [id])
  specification specifications  @relation(fields: [specificationId], references: [id])

  @@id([productId, specificationId])
}

model wishlist {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  productVariantId String   @db.Uuid
  createdAt        DateTime @default(now())

  user           users             @relation(fields: [userId], references: [id])
  productVariant products_variants @relation(fields: [productVariantId], references: [id])

  @@unique([userId, productVariantId])
}

model cart_items {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  productVariantId String   @db.Uuid
  quantity         Int      @default(1)
  unitPrice        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           users             @relation(fields: [userId], references: [id])
  productVariant products_variants @relation(fields: [productVariantId], references: [id])
}

model orders {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  paymentMethodId   String        @db.Uuid
  voucherId         String?       @db.Uuid
  shippingAddressId String        @db.Uuid
  subtotalAmount    Decimal       @db.Decimal(10, 2)
  shippingFee       Decimal       @default("0.00") @db.Decimal(10, 2)
  voucherDiscount   Decimal       @default("0.00") @db.Decimal(10, 2)
  totalAmount       Decimal       @db.Decimal(10, 2)
  orderStatus       OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)
  orderDate         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user            users            @relation(fields: [userId], references: [id])
  paymentMethod   payment_methods  @relation(fields: [paymentMethodId], references: [id])
  voucher         vouchers?        @relation(fields: [voucherId], references: [id])
  shippingAddress user_addresses   @relation(fields: [shippingAddressId], references: [id])
  orderItems      order_items[]
  voucherUsages   voucher_usages[]
  transactions    payment_transactions[]
}

model order_items {
  id               String   @id @default(uuid()) @db.Uuid
  orderId          String   @db.Uuid
  productVariantId String   @db.Uuid
  quantity         Int
  unitPrice        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())

  order          orders            @relation(fields: [orderId], references: [id])
  productVariant products_variants @relation(fields: [productVariantId], references: [id])
  review         reviews?
}

model reviews {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  orderItemId String   @unique @db.Uuid
  rating      Int
  comment     String?
  isApproved  ReviewStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      users       @relation(fields: [userId], references: [id])
  orderItem order_items @relation(fields: [orderItemId], references: [id])
}

model payment_methods {
  id          String   @id @default(uuid()) @db.Uuid
  name        String @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders orders[]
  payment_transactions payment_transactions[]
}

model payment_transactions {
  id              String   @id @default(uuid()) @db.Uuid

  orderId         String   @db.Uuid
  paymentMethodId String   @db.Uuid

  amount          Decimal  @db.Decimal(10, 2)
  transactionRef  String?
  status          PaymentTransactionStatus
  payload         Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           orders            @relation(fields: [orderId], references: [id])
  paymentMethod   payment_methods   @relation(fields: [paymentMethodId], references: [id])
}


model vouchers {
  id             String       @id @default(uuid()) @db.Uuid
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderValue  Decimal      @default("0.00") @db.Decimal(10, 2)
  maxUses        Int?
  maxUsesPerUser Int?
  usesCount      Int          @default(0)
  startDate      DateTime?
  endDate        DateTime?
  priority       Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  orders        orders[]
  actions       voucher_actions[]
  targets       voucher_targets[]
  voucherUsers  voucher_user[]
  voucherUsages voucher_usages[]
}

model voucher_actions {
  id                   String            @id @default(uuid()) @db.Uuid
  voucherId            String            @db.Uuid
  actionType           VoucherActionType
  value                String?
  buyQuantity          Int?
  getQuantity          Int?
  giftProductVariantId String?           @db.Uuid
  createdAt            DateTime          @default(now())

  voucher     vouchers           @relation(fields: [voucherId], references: [id])
  giftVariant products_variants? @relation(fields: [giftProductVariantId], references: [id])
}

model voucher_targets {
  id         String   @id @default(uuid()) @db.Uuid
  voucherId  String   @db.Uuid
  targetType String // "product" | "category" | "brand" | "all" (có thể tách enum nếu cần)
  targetId   String?
  createdAt  DateTime @default(now())

  voucher vouchers @relation(fields: [voucherId], references: [id])
}

model voucher_user {
  id        String   @id @default(uuid()) @db.Uuid
  voucherId String   @db.Uuid
  userId    String   @db.Uuid
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  voucher vouchers @relation(fields: [voucherId], references: [id])
  user    users    @relation(fields: [userId], references: [id])

  @@unique([voucherId, userId])
}

model voucher_usages {
  id        String   @id @default(uuid()) @db.Uuid
  voucherId String   @db.Uuid
  userId    String   @db.Uuid
  orderId   String   @db.Uuid
  usedAt    DateTime @default(now())

  voucher vouchers @relation(fields: [voucherId], references: [id])
  user    users    @relation(fields: [userId], references: [id])
  order   orders   @relation(fields: [orderId], references: [id])
}
