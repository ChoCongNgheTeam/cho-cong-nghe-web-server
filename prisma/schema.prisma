generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------- ENUMS ---------------------
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

enum AddressType {
  HOME
  OFFICE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}


enum DiscountType {
  PERCENTAGE
  FIXED
}

enum VoucherActionType {
  DISCOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// --------------------- MODELS ---------------------

model users {
  id           String   @id @default(uuid()) @db.Uuid
  userName     String?  @unique
  email        String   @unique
  passwordHash String
  fullName     String?
  phone        String?
  gender       Gender?
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  avatarImage  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userAddresses user_addresses[]
  orders        orders[]
  cartItems     cart_items[]
  wishlist      wishlist[]
  reviews       reviews[]
  voucherUsers  voucher_user[]
  voucherUsages voucher_usages[]

  passwordResetTokens password_reset_tokens[]
  refreshTokens refresh_tokens[]
}

model password_reset_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid 
  user      users    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model refresh_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
}

model user_addresses {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @db.Uuid
  contactName   String
  phone         String
  provinceId    Int
  districtId    Int
  wardId        Int?
  detailAddress String
  type          AddressType?
  isDefault     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user users @relation(fields: [userId], references: [id])

  orders orders[]
  @@unique([userId, detailAddress, phone])
}

model brands {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  brandImage  String?
  slug        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products products[]
}

model categories {
  id            String   @id @default(uuid()) @db.Uuid
  name  String @unique
  parentId      String?  @db.Uuid
  description   String?
  categoryImage String?
  slug          String   @unique
  position      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent            categories?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children          categories[]         @relation("CategoryHierarchy")
  products products[]
  @@unique([parentId, position])
}

