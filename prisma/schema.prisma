generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------- ENUMS ---------------------
enum CampaignType {
  RANKING
  CAMPAIGN
  SEASONAL
  EVENT
  FLASH_SALE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum OrderStatus {
  PENDING            // Đơn thật đã được staff confirm / Chờ xử lý
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUND_PENDING
  REFUNDED
}

enum PaymentTransactionStatus {
  PENDING
  COMPLETED
  UNDERPAID
  OVERPAID
  FAILED
  REFUNDED
}

enum DiscountType {
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
}

enum TargetType {
  PRODUCT
  PRODUCT_VARIANT
  CATEGORY
  BRAND
  ALL
  ATTRIBUTE
}

enum StackingGroup {
  PERCENT
  FIXED
  FLASH
  BANK
  GIFT
}

enum ApplyType {
  STACKABLE
  EXCLUSIVE
}


enum PromotionActionType {
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  BUY_X_GET_Y
  GIFT_PRODUCT
  FREE_SHIPPING
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommentTargetType {
  BLOG
  PRODUCT
  PAGE
}

enum PageType {
  PAGE
  POLICY
}

enum PolicyType {
  DATA_PRIVACY          // Cho DataPrivacy
  DELIVERY              // Cho Delivery
  DELIVERY_INSTALLATION // Cho DeliveryInstallation
  INSTALLMENT           // Cho Installment
  LOYALTY               // Cho Loyalty
  MOBILE_NETWORK        // Cho MobileNetwork
  PRIVACY               // Cho Privacy
  RETURN                // Cho Return
  TECHNICAL_SUPPORT     // Cho Technical-support
  UNBOXING              // Cho unboxing
  WARRANTY              // Cho warranty-policy
}

enum FilterType {
  RANGE
  ENUM
  BOOLEAN
}

enum VariantDisplayType {
  SELECTOR
  CARD
}

enum BlogType {
  TIN_MOI
  DANH_GIA
  KHUYEN_MAI
  DIEN_MAY
  NOI_BAT
}


// SOFT DELETE: users là entity chính, staff/admin cần trash
// deletedBy tham chiếu chính nó (self-ref) — dùng String thay vì Uuid relation để tránh circular
model users {
  id           String    @id @default(uuid()) @db.Uuid
  userName     String?   @unique
  email        String    @unique
  passwordHash String?
  fullName     String?
  phone        String?
  gender       Gender?
  dateOfBirth  DateTime?
  role         UserRole  @default(CUSTOMER)
  isActive     Boolean   @default(true)
  notifications notifications[]
  fcmTokens     fcm_tokens[]
  avatarPath   String?
  avatarImage  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  

  // --- Soft Delete ---
  deletedAt    DateTime?
  deletedBy    String?   @db.Uuid  // ID của admin/staff thực hiện xóa

  orders        orders[]
  userAddresses user_addresses[]
  cartItems     cart_items[]
  wishlist      wishlist[]
  reviews       reviews[]
  voucherUsers  voucher_user[]
  voucherUsages voucher_usages[]
  blogs         blogs[]
  comments      comments[]

  passwordResetTokens password_reset_tokens[]
  refreshTokens       refresh_tokens[]
  oauthAccounts       oauth_accounts[]

  @@index([deletedAt]) // để query isDeleted nhanh hơn
}

// CASCADE: oauth_accounts gắn chặt với user, xóa user thì xóa luôn
model oauth_accounts {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  provider          String    // "google" | "facebook" | "apple"
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// CASCADE: token gắn chặt với user
model password_reset_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum RefreshTokenTTLType {
  short
  long
}

// CASCADE: refresh token gắn chặt với user
model refresh_tokens {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String              @db.Uuid
  token             String              @unique
  expiresAt         DateTime
  absoluteExpiresAt DateTime
  ttlType           RefreshTokenTTLType
  revokedAt         DateTime?
  createdAt         DateTime            @default(now())

  deviceId  String?
  userAgent String?
  ip        String?

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user_addresses {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  contactName   String
  phone         String
  
  // Thay provinceId/wardId bằng code từ external API
  provinceCode  Int         // VD: 79 (TP.HCM)
  provinceName  String      // Snapshot tên, tránh phụ thuộc external API lúc đọc
  wardCode      Int         // VD: 26560
  wardName      String      // Snapshot tên
  
  detailAddress String
  type          AddressType?
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deletedAt     DateTime?
  deletedBy     String?     @db.Uuid

  user          users       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, detailAddress, phone])
  @@index([userId])
  @@index([deletedAt])
}

// SOFT DELETE: brands là entity chính của catalog
model brands {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  imagePath   String?
  imageUrl    String?
  slug        String    @unique
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // --- Soft Delete ---
  deletedAt   DateTime?
  deletedBy   String?   @db.Uuid

  products products[]

  @@index([deletedAt])
}

// SOFT DELETE: categories là entity chính của catalog
model categories {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  parentId    String?   @db.Uuid
  description String?
  imagePath   String?
  imageUrl    String?
  slug        String    @unique
  position    Int       @default(0)
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // --- Soft Delete ---
  deletedAt   DateTime?
  deletedBy   String?   @db.Uuid

  parent                 categories?               @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children               categories[]              @relation("CategoryHierarchy")
  products               products[]
  categorySpecifications category_specifications[]
  variantAttributes      category_variant_attributes[]
  campaignCategories     campaign_categories[]

  @@unique([parentId, position])
  @@unique([name, parentId])
  @@index([deletedAt])
}

// SOFT DELETE: campaigns là entity marketing, cần archive/restore
model campaigns {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  type        CampaignType
  description String?
  startDate  DateTime? @db.Timestamptz
  endDate    DateTime? @db.Timestamptz
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // --- Soft Delete ---
  deletedAt   DateTime?
  deletedBy   String?      @db.Uuid

  categories campaign_categories[]

  @@index([deletedAt])
}

// CASCADE: campaign_categories là bảng join, xóa campaign → xóa luôn
model campaign_categories {
  id          String  @id @default(uuid()) @db.Uuid
  campaignId  String  @db.Uuid
  categoryId  String  @db.Uuid
  position    Int
  imagePath   String
  imageUrl    String?
  title       String?
  description String?

  campaign campaigns  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([campaignId, categoryId])
  @@index([campaignId])
  @@index([categoryId])
}

// SOFT DELETE: products là entity chính của catalog
model products {
  id             String    @id @default(uuid()) @db.Uuid
  brandId        String    @db.Uuid
  categoryId     String    @db.Uuid
  name           String
  description    String?
  slug           String    @unique
  viewsCount     BigInt    @default(0)
  totalSoldCount Int       @default(0)
  ratingAverage  Decimal   @default("0.00") @db.Decimal(3, 2)
  ratingCount    Int       @default(0)
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  variantDisplay VariantDisplayType @default(SELECTOR)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // --- Soft Delete ---
  deletedAt      DateTime?
  deletedBy      String?   @db.Uuid

  brand                 brands                   @relation(fields: [brandId], references: [id])
  category              categories               @relation(fields: [categoryId], references: [id])
  img                   product_color_images[]
  variants              products_variants[]
  productSpecifications product_specifications[]
  wishlist              wishlist[]

  @@index([isActive, totalSoldCount])
  @@index([deletedAt])
}

model attributes {
  id        String   @id @default(uuid())
  code      String   @unique // color, storage, inch
  name      String           // Màu sắc, Bộ nhớ, Kích thước
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  options    attributes_options[]
  categories category_variant_attributes[]
}

model attributes_options {
  id          String   @id @default(uuid()) @db.Uuid
  attributeId String
  value       String
  label       String
   isActive    Boolean  @default(true) 

  attribute         attributes          @relation(fields: [attributeId], references: [id])
  variantAttributes variants_attributes[]

  @@unique([attributeId, value])
}

model category_variant_attributes {
  categoryId  String @db.Uuid
  attributeId String

  category  categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute attributes @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeId])
}

// SOFT DELETE: product variant — cần soft delete riêng vì có thể restore
// Khi product bị soft delete thì variant vẫn giữ nguyên (không cascade soft delete)
// Hard delete product → cascade hard delete variants
model products_variants {
  id        String    @id @default(uuid()) @db.Uuid
  productId String    @db.Uuid
  code      String?   @unique // SKU
  price     Decimal   @db.Decimal(12, 2)
  quantity  Int       @default(10)
  soldCount Int       @default(0)
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // --- Soft Delete ---
  deletedAt DateTime?
  deletedBy String?   @db.Uuid

  product           products             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantAttributes variants_attributes[]
  cartItems         cart_items[]
  orderItems        order_items[]
  

  @@index([deletedAt])
}

// CASCADE: ảnh gắn chặt với product
model product_color_images {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  color     String
  imagePath String
  imageUrl  String?
  altText   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, imagePath])
  @@index([productId, color])
}

// CASCADE: variant attributes gắn chặt với variant
model variants_attributes {
  id                String   @id @default(uuid()) @db.Uuid
  productVariantId  String   @db.Uuid
  attributeOptionId String   @db.Uuid
  createdAt         DateTime @default(now())

  productVariant  products_variants  @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  attributeOption attributes_options @relation(fields: [attributeOptionId], references: [id])

  @@unique([productVariantId, attributeOptionId])
}

model category_specifications {
  categoryId      String @db.Uuid
  specificationId String @db.Uuid
  groupName       String
  isRequired      Boolean @default(false)
  sortOrder       Int     @default(0)

  category      categories     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  specification specifications @relation(fields: [specificationId], references: [id], onDelete: Cascade)

  @@id([categoryId, specificationId])
}

model specifications {
  id           String    @id @default(uuid()) @db.Uuid
  key          String    @unique
  name         String
  group        String    @default("Thông số khác")
  unit         String?
  icon         String?
  isActive     Boolean    @default(true)
  isFilterable Boolean   @default(false)
  filterType   FilterType?
  isRequired   Boolean   @default(false)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  productSpecifications product_specifications[]
  allowedInCategories   category_specifications[]
}

// CASCADE: specs gắn với product
model product_specifications {
  productId       String  @db.Uuid
  specificationId String  @db.Uuid
  value           String
  sortOrder       Int     @default(0)
  isHighlight     Boolean

  product       products       @relation(fields: [productId], references: [id], onDelete: Cascade)
  specification specifications @relation(fields: [specificationId], references: [id])

  @@id([productId, specificationId])
}

// CASCADE: wishlist gắn với user, SET NULL nếu variant bị soft delete thì giữ nguyên
// Nếu user bị hard delete → xóa wishlist; nếu variant bị hard delete → xóa wishlist
model wishlist {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  productId String   @db.Uuid
  createdAt        DateTime @default(now())

  user           users             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        products          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// CASCADE theo user; giỏ hàng không cần soft delete
model cart_items {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  productVariantId String   @db.Uuid
  quantity         Int      @default(1)
  unitPrice        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           users             @relation(fields: [userId], references: [id], onDelete: Cascade)
  productVariant products_variants @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
}

// SOFT DELETE: orders — không được hard delete, cần audit trail
// cancelledAt riêng để track lý do hủy; deletedAt để ẩn khỏi danh sách
model orders {
  id                String        @id @default(uuid()) @db.Uuid
  orderCode         String        @unique

  userId            String        @db.Uuid
  paymentMethodId   String        @db.Uuid
  voucherId         String?       @db.Uuid

  // ===== ADDRESS SNAPSHOT =====
  shippingAddressId String?       @db.Uuid // chỉ để trace (NO FK)

  shippingContactName String
  shippingPhone       String
  shippingProvince    String
  shippingWard        String
  shippingDetail      String

  // ===== MONEY =====
  subtotalAmount    Decimal       @db.Decimal(10, 2)
  shippingFee       Decimal       @default("0.00") @db.Decimal(10, 2)
  voucherDiscount   Decimal       @default("0.00") @db.Decimal(10, 2)
  totalAmount       Decimal       @db.Decimal(10, 2)

  // ===== STATUS =====
  orderStatus       OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(UNPAID)

  // ===== PAYMENT IDS =====
  bankTransferCode      String?   @unique
  momoOrderId           String?   @unique
  vnpayTxnRef           String?   @unique
  zaloPayTransId        String?   @unique
  stripePaymentIntentId String?

  orderDate         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  bankTransferQrUrl     String?
  bankTransferContent   String?
  bankTransferExpiredAt DateTime?
  paymentExpiredAt      DateTime?
  paymentRedirectUrl    String?

  // ===== CHATBOT REQUEST TRACKING =====
  isChatbotRequest        Boolean       @default(false)        // true = request từ chatbot
  requestAcknowledgedAt   DateTime?                            // Khi staff confirm
  requestRejectionReason  String?                              // Nếu staff từ chối

   // ===== REFUND AUDIT =====
  refundedAt     DateTime?
  refundedBy     String?   @db.Uuid  // userId của staff xác nhận
  refundNote     String?             // ghi chú hoàn tiền (tuỳ chọn)

  // ===== RELATIONS =====
  user            users                  @relation(fields: [userId], references: [id])
  paymentMethod   payment_methods        @relation(fields: [paymentMethodId], references: [id])
  voucher         vouchers?              @relation(fields: [voucherId], references: [id])

  orderItems      order_items[]
  voucherUsages   voucher_usages[]
  transactions    payment_transactions[]

  @@index([userId])
  @@index([orderStatus])
  @@index([orderDate])
}

// CASCADE theo order; order_items là dữ liệu giao dịch, không soft delete độc lập
model order_items {
  id               String   @id @default(uuid()) @db.Uuid
  orderId          String   @db.Uuid
  productVariantId String   @db.Uuid
  quantity         Int
  unitPrice        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())

  order          orders            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Restrict vì cần giữ lịch sử mua hàng dù variant bị xóa
  productVariant products_variants @relation(fields: [productVariantId], references: [id])
  review         reviews?
}

// SOFT DELETE: reviews — admin có thể ẩn/restore review
model reviews {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  orderItemId String       @unique @db.Uuid
  rating      Int
  comment     String?
  isApproved  ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // --- Soft Delete ---
  deletedAt   DateTime?
  deletedBy   String?      @db.Uuid

  user      users       @relation(fields: [userId], references: [id])
  orderItem order_items @relation(fields: [orderItemId], references: [id])

  @@index([deletedAt])
}

// Không soft delete: payment_methods là config hệ thống, dùng isActive để disable
model payment_methods {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders               orders[]
  payment_transactions payment_transactions[]
}

// Không soft delete: transaction là audit log tài chính, không được xóa
model payment_transactions {
  id              String                   @id @default(uuid()) @db.Uuid
  orderId         String                   @db.Uuid
  paymentMethodId String                   @db.Uuid
  amount          Decimal                  @db.Decimal(10, 2)
  transactionRef  String?
  status          PaymentTransactionStatus
  payload         Json?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  order         orders          @relation(fields: [orderId], references: [id])
  paymentMethod payment_methods @relation(fields: [paymentMethodId], references: [id])
}

// SOFT DELETE: vouchers — cần archive/restore, không xóa thật vì ảnh hưởng lịch sử order
model vouchers {
  id               String       @id @default(uuid()) @db.Uuid
  code             String       @unique
  description      String?
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  minOrderValue    Decimal      @default("0.00") @db.Decimal(10, 2)
  maxDiscountValue Decimal?     @db.Decimal(10, 2)
  maxUses          Int?
  maxUsesPerUser   Int?
  usesCount        Int          @default(0)
  startDate  DateTime? @db.Timestamptz
  endDate    DateTime? @db.Timestamptz
  priority         Int          @default(0)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // --- Soft Delete ---
  deletedAt        DateTime?
  deletedBy        String?      @db.Uuid

  orders        orders[]
  targets       voucher_targets[]
  voucherUsers  voucher_user[]
  voucherUsages voucher_usages[]

  @@index([deletedAt])
}

// CASCADE: targets gắn với voucher
model voucher_targets {
  id         String     @id @default(uuid()) @db.Uuid
  voucherId  String     @db.Uuid
  targetType TargetType
  targetId   String?
  createdAt  DateTime   @default(now())

  voucher vouchers @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

// CASCADE: voucher_user gắn với voucher và user
model voucher_user {
  id        String   @id @default(uuid()) @db.Uuid
  voucherId String   @db.Uuid
  userId    String   @db.Uuid
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  voucher vouchers @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
}

// Không xóa: voucher_usages là audit log giao dịch
model voucher_usages {
  id        String   @id @default(uuid()) @db.Uuid
  voucherId String   @db.Uuid
  userId    String   @db.Uuid
  orderId   String   @db.Uuid
  usedAt    DateTime @default(now())

  voucher vouchers @relation(fields: [voucherId], references: [id])
  user    users    @relation(fields: [userId], references: [id])
  order   orders   @relation(fields: [orderId], references: [id])
}

// SOFT DELETE: promotions — cần archive/restore
model promotions {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique
  description      String?
  priority         Int       @default(0)
  isActive         Boolean   @default(true)
  startDate  DateTime? @db.Timestamptz
  endDate    DateTime? @db.Timestamptz
  minOrderValue    Decimal?  @db.Decimal(12, 2)
  maxDiscountValue Decimal?  @db.Decimal(12, 2)
  usageLimit       Int?
  usedCount        Int       @default(0)
  createdAt        DateTime  @default(now())

  applyType      ApplyType     @default(EXCLUSIVE)
  stackingGroup  StackingGroup @default(PERCENT)
  stopProcessing Boolean       @default(false)

  // --- Soft Delete ---
  deletedAt        DateTime?
  deletedBy        String?   @db.Uuid

  rules   promotion_rules[]
  targets promotion_targets[]

  @@index([deletedAt])
}

// CASCADE: rules gắn chặt với promotion
model promotion_rules {
  id                   String              @id @default(uuid()) @db.Uuid
  promotionId          String              @db.Uuid
  actionType           PromotionActionType
  discountValue        Decimal?            @db.Decimal(10, 2)
  buyQuantity          Int?
  getQuantity          Int?
  giftProductVariantId String?             @db.Uuid
  createdAt            DateTime            @default(now())

  promotion promotions @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

// CASCADE: targets gắn chặt với promotion
model promotion_targets {
  id          String     @id @default(uuid()) @db.Uuid
  promotionId String     @db.Uuid
  targetType  TargetType
  targetId    String?
  targetCode  String?    // "storage"
  targetValue String?    // "128GB"
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  promotion promotions @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

// SOFT DELETE: blogs — admin/staff cần trash, restore
model blogs {
  id          String     @id @default(uuid()) @db.Uuid
  authorId    String     @db.Uuid
  title       String
  slug        String     @unique
  content     String
  imagePath   String?
  imageUrl    String?
  viewCount   Int        @default(0)
  type        BlogType   @default(TIN_MOI)
  status      BlogStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?

  // --- Soft Delete ---
  deletedAt   DateTime?
  deletedBy   String?    @db.Uuid

  author   users      @relation(fields: [authorId], references: [id])
  comments comments[]

  @@index([deletedAt])
}

// SOFT DELETE: comments — admin có thể ẩn/restore comment
model comments {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String?           @db.Uuid
  content    String
  targetType CommentTargetType
  targetId   String
  parentId   String?           @db.Uuid
  isApproved Boolean           @default(false)
  createdAt  DateTime          @default(now())

  // --- Soft Delete ---
  deletedAt  DateTime?
  deletedBy  String?           @db.Uuid

  user    users?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent  comments?  @relation("CommentParent", fields: [parentId], references: [id])
  replies comments[] @relation("CommentParent")
  blogs   blogs[]

  @@index([targetType, targetId])
  @@index([deletedAt])
}

// SOFT DELETE: pages/policies — cần unpublish thay vì xóa thật
model pages {
  id          String      @id @default(uuid()) @db.Uuid
  type        PageType
  policyType  PolicyType?
  title       String
  slug        String      @unique
  content     String
  isPublished Boolean     @default(true)
  priority    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // --- Soft Delete ---
  deletedAt   DateTime?
  deletedBy   String?     @db.Uuid

  @@index([deletedAt])
}

enum MediaType {
  SLIDER
  BANNER
}

enum MediaPosition {
  HOME_TOP
  BELOW_SLIDER
  HOME_SECTION_1
  HOME_SECTION_2
}

// SOFT DELETE: image_media — banner/slider cần trash, restore
model image_media {
  id        String        @id @default(uuid()) @db.Uuid
  type      MediaType
  position  MediaPosition
  title     String?
  subTitle  String?
  imagePath String?
  imageUrl  String?
  linkUrl   String?
  order     Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // --- Soft Delete ---
  deletedAt DateTime?
  deletedBy String?       @db.Uuid

  @@index([type, position])
  @@index([isActive])
  @@index([deletedAt])
}

model notifications {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model fcm_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  device    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum NotificationType {
  WELCOME_VOUCHER
  VOUCHER_EXPIRING
  VOUCHER_ASSIGNED
  CAMPAIGN_PROMOTION
  ORDER_STATUS
  USER_INACTIVE
  COMMENT_NEW
  REVIEW_NEW
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AiContentType {
  PRODUCT_DESCRIPTION
  BLOG_POST
}

model ai_contents {
  id          String        @id @default(uuid()) @db.Uuid
  type        AiContentType
  referenceId String?       @db.Uuid  // productId nếu type = PRODUCT_DESCRIPTION
  focusKeyword String
  inputData   Json          // Raw input để regenerate nếu cần
  outputContent String      @db.Text
  seoScore    Int           // 0-100
  seoDetails  Json          // Chi tiết SEO score
  createdBy   String        @db.Uuid  // userId của admin/staff
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
 
  @@index([type, referenceId])
  @@index([createdBy])
  @@index([createdAt])
}

model chat_sessions {
  id        String   @id @default(uuid()) @db.Uuid
  sessionKey String  @unique  // UUID từ FE localStorage
  messages  Json    // Array of {role, content}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // Tự động xóa sau 24h
 
  @@index([sessionKey])
  @@index([expiresAt])
}