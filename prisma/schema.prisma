generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model users {
  id                         String                  @id @default(uuid()) @db.Uuid
  userName                   String?                 @unique
  email                      String                  @unique
  passwordHash               String?
  fullName                   String?
  phone                      String?
  gender                     Gender?
  dateOfBirth                DateTime?
  role                       UserRole                @default(CUSTOMER)
  isActive                   Boolean                 @default(true)
  avatarImage                String?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  deletedAt                  DateTime?
  deletedBy                  String?                 @db.Uuid
  avatarPath                 String?
  notifEmail                 Boolean                 @default(true)
  notifOrderStatus           Boolean                 @default(true)
  notifPush                  Boolean                 @default(true)
  notifReviewNew             Boolean                 @default(true)
  notifUserInactive          Boolean                 @default(true)
  notifWeeklyReport          Boolean                 @default(false)
  isVerified                 Boolean                 @default(false)
  verificationToken          String?                 @unique
  verificationTokenExpiresAt DateTime?
  blogs                      blogs[]
  cartItems                  cart_items[]
  comments                   comments[]
  fcmTokens                  fcm_tokens[]
  notifications              notifications[]
  oauthAccounts              oauth_accounts[]
  orders                     orders[]
  passwordResetTokens        password_reset_tokens[]
  refreshTokens              refresh_tokens[]
  reviews                    reviews[]
  staffPermissions           staff_permissions?
  userAddresses              user_addresses[]
  voucherUsages              voucher_usages[]
  voucherUsers               voucher_user[]
  wishlist                   wishlist[]
  chatSessions        chat_sessions[]
  userPreferences     user_preferences[]
  chatMemoryVectors   chat_memory_vectors[]

  @@index([deletedAt])
}

model staff_permissions {
  userId           String   @id @db.Uuid
  canViewOrders    Boolean  @default(false)
  canCreateOrder   Boolean  @default(false)
  canUpdateOrder   Boolean  @default(false)
  canViewProducts  Boolean  @default(false)
  canUpdateStock   Boolean  @default(false)
  canBlogs         Boolean  @default(false)
  canMedia         Boolean  @default(false)
  canCampaigns     Boolean  @default(false)
  canVouchers      Boolean  @default(false)
  canPromotions    Boolean  @default(false)
  canAiContent     Boolean  @default(false)
  canReviews       Boolean  @default(false)
  canComments      Boolean  @default(false)
  canNotifications Boolean  @default(false)
  canViewUsers     Boolean  @default(false)
  canAnalytics     Boolean  @default(false)
  canPaymentView   Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  user             users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model oauth_accounts {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  user              users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model password_reset_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model refresh_tokens {
  id                String              @id @default(uuid()) @db.Uuid
  userId            String              @db.Uuid
  token             String              @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime            @default(now())
  deviceId          String?
  userAgent         String?
  ip                String?
  ttlType           RefreshTokenTTLType
  absoluteExpiresAt DateTime
  browser           String?
  deviceName        String?
  lastUsedAt        DateTime?
  location          String?
  user              users               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user_addresses {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @db.Uuid
  contactName   String
  phone         String
  detailAddress String
  type          AddressType?
  isDefault     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  deletedBy     String?      @db.Uuid
  provinceCode  Int
  provinceName  String
  wardCode      Int
  wardName      String
  user          users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, detailAddress, phone])
  @@index([userId])
  @@index([deletedAt])
}

model brands {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  imagePath   String?
  imageUrl    String?
  slug        String     @unique
  isFeatured  Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  deletedBy   String?    @db.Uuid
  products    products[]

  @@index([deletedAt])
}

model categories {
  id                     String                        @id @default(uuid()) @db.Uuid
  name                   String
  parentId               String?                       @db.Uuid
  description            String?
  imagePath              String?
  imageUrl               String?
  slug                   String                        @unique
  position               Int                           @default(0)
  isFeatured             Boolean                       @default(false)
  isActive               Boolean                       @default(true)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  deletedAt              DateTime?
  deletedBy              String?                       @db.Uuid
  campaignCategories     campaign_categories[]
  parent                 categories?                   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children               categories[]                  @relation("CategoryHierarchy")
  categorySpecifications category_specifications[]
  variantAttributes      category_variant_attributes[]
  products               products[]

  @@unique([parentId, position])
  @@unique([name, parentId])
  @@index([deletedAt])
}

model campaigns {
  id          String                @id @default(uuid()) @db.Uuid
  name        String
  slug        String                @unique
  type        CampaignType
  description String?
  startDate   DateTime?             @db.Timestamptz(6)
  endDate     DateTime?             @db.Timestamptz(6)
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  deletedBy   String?               @db.Uuid
  categories  campaign_categories[]

  @@index([deletedAt])
}

model campaign_categories {
  id          String     @id @default(uuid()) @db.Uuid
  campaignId  String     @db.Uuid
  categoryId  String     @db.Uuid
  position    Int
  imageUrl    String?
  title       String?
  description String?
  imagePath   String
  campaign    campaigns  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category    categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([campaignId, categoryId])
  @@index([campaignId])
  @@index([categoryId])
}

model products {
  id                    String                   @id @default(uuid()) @db.Uuid
  brandId               String                   @db.Uuid
  categoryId            String                   @db.Uuid
  name                  String
  description           String?
  slug                  String                   @unique
  viewsCount            BigInt                   @default(0)
  ratingAverage         Decimal                  @default(0.00) @db.Decimal(3, 2)
  ratingCount           Int                      @default(0)
  isActive              Boolean                  @default(true)
  isFeatured            Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  totalSoldCount        Int                      @default(0)
  deletedAt             DateTime?
  deletedBy             String?                  @db.Uuid
  variantDisplay        VariantDisplayType       @default(SELECTOR)
  img                   product_color_images[]
  productSpecifications product_specifications[]
  brand                 brands                   @relation(fields: [brandId], references: [id])
  category              categories               @relation(fields: [categoryId], references: [id])
  variants              products_variants[]
  vectorData            products_vector?
  wishlist              wishlist[]

  @@index([isActive, totalSoldCount])
  @@index([deletedAt])
}

model attributes {
  id         String                        @id @default(uuid())
  code       String                        @unique
  name       String
  createdAt  DateTime                      @default(now())
  isActive   Boolean                       @default(true)
  options    attributes_options[]
  categories category_variant_attributes[]
}

model attributes_options {
  id                String                @id @default(uuid()) @db.Uuid
  attributeId       String
  value             String
  label             String
  isActive          Boolean               @default(true)
  attribute         attributes            @relation(fields: [attributeId], references: [id])
  variantAttributes variants_attributes[]

  @@unique([attributeId, value])
}

model category_variant_attributes {
  categoryId  String     @db.Uuid
  attributeId String
  attribute   attributes @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  category    categories @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([categoryId, attributeId])
}

model products_variants {
  id                String                @id @default(uuid()) @db.Uuid
  productId         String                @db.Uuid
  code              String?               @unique
  price             Decimal               @db.Decimal(12, 2)
  quantity          Int                   @default(10)
  soldCount         Int                   @default(0)
  isDefault         Boolean               @default(false)
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  deletedBy         String?               @db.Uuid
  cartItems         cart_items[]
  orderItems        order_items[]
  product           products              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantAttributes variants_attributes[]

  @@index([deletedAt])
}

model product_color_images {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  color     String
  imagePath String
  imageUrl  String?
  altText   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, imagePath])
  @@index([productId, color])
}

model variants_attributes {
  id                String             @id @default(uuid()) @db.Uuid
  productVariantId  String             @db.Uuid
  attributeOptionId String             @db.Uuid
  createdAt         DateTime           @default(now())
  attributeOption   attributes_options @relation(fields: [attributeOptionId], references: [id])
  productVariant    products_variants  @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, attributeOptionId])
}

model category_specifications {
  categoryId      String         @db.Uuid
  specificationId String         @db.Uuid
  groupName       String
  isRequired      Boolean        @default(false)
  sortOrder       Int            @default(0)
  category        categories     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  specification   specifications @relation(fields: [specificationId], references: [id], onDelete: Cascade)

  @@id([categoryId, specificationId])
}

model specifications {
  id                    String                    @id @default(uuid()) @db.Uuid
  key                   String                    @unique
  name                  String
  group                 String                    @default("Thông số khác")
  unit                  String?
  icon                  String?
  createdAt             DateTime                  @default(now())
  isFilterable          Boolean                   @default(false)
  isRequired            Boolean                   @default(false)
  sortOrder             Int                       @default(0)
  filterType            FilterType?
  isActive              Boolean                   @default(true)
  allowedInCategories   category_specifications[]
  productSpecifications product_specifications[]
}

model product_specifications {
  productId       String         @db.Uuid
  specificationId String         @db.Uuid
  value           String
  sortOrder       Int            @default(0)
  isHighlight     Boolean
  product         products       @relation(fields: [productId], references: [id], onDelete: Cascade)
  specification   specifications @relation(fields: [specificationId], references: [id])

  @@id([productId, specificationId])
}

model wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  productId String   @db.Uuid
  product   products @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model cart_items {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  productVariantId String            @db.Uuid
  quantity         Int               @default(1)
  unitPrice        Decimal           @db.Decimal(10, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productVariant   products_variants @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  user             users             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model orders {
  id                     String                 @id @default(uuid()) @db.Uuid
  userId                 String                 @db.Uuid
  paymentMethodId        String                 @db.Uuid
  voucherId              String?                @db.Uuid
  shippingAddressId      String?                @db.Uuid
  subtotalAmount         Decimal                @db.Decimal(10, 2)
  shippingFee            Decimal                @default(0.00) @db.Decimal(10, 2)
  voucherDiscount        Decimal                @default(0.00) @db.Decimal(10, 2)
  totalAmount            Decimal                @db.Decimal(10, 2)
  orderStatus            OrderStatus            @default(PENDING)
  paymentStatus          PaymentStatus          @default(UNPAID)
  orderDate              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  orderCode              String                 @unique
  bankTransferCode       String?                @unique
  momoOrderId            String?                @unique
  vnpayTxnRef            String?                @unique
  zaloPayTransId         String?                @unique
  stripePaymentIntentId  String?
  shippingContactName    String
  shippingDetail         String
  shippingPhone          String
  shippingProvince       String
  shippingWard           String
  bankTransferContent    String?
  bankTransferExpiredAt  DateTime?
  bankTransferQrUrl      String?
  paymentExpiredAt       DateTime?
  paymentRedirectUrl     String?
  isChatbotRequest       Boolean                @default(false)
  requestAcknowledgedAt  DateTime?
  requestRejectionReason String?
  refundNote             String?
  refundedAt             DateTime?
  refundedBy             String?                @db.Uuid
  orderItems             order_items[]
  paymentMethod          payment_methods        @relation(fields: [paymentMethodId], references: [id])
  user                   users                  @relation(fields: [userId], references: [id])
  voucher                vouchers?              @relation(fields: [voucherId], references: [id])
  transactions           payment_transactions[]
  voucherUsages          voucher_usages[]

  @@index([userId])
  @@index([orderStatus])
  @@index([orderDate])
}

model order_items {
  id               String            @id @default(uuid()) @db.Uuid
  orderId          String            @db.Uuid
  productVariantId String            @db.Uuid
  quantity         Int
  unitPrice        Decimal           @db.Decimal(10, 2)
  createdAt        DateTime          @default(now())
  order            orders            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   products_variants @relation(fields: [productVariantId], references: [id])
  review           reviews?
}

model reviews {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  orderItemId String       @unique @db.Uuid
  rating      Int
  comment     String?
  isApproved  ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  deletedBy   String?      @db.Uuid
  orderItem   order_items  @relation(fields: [orderItemId], references: [id])
  user        users        @relation(fields: [userId], references: [id])

  @@index([deletedAt])
}

model payment_methods {
  id                   String                 @id @default(uuid()) @db.Uuid
  name                 String                 @unique
  description          String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  code                 String                 @unique
  orders               orders[]
  payment_transactions payment_transactions[]
}

model payment_transactions {
  id              String                   @id @default(uuid()) @db.Uuid
  orderId         String                   @db.Uuid
  paymentMethodId String                   @db.Uuid
  amount          Decimal                  @db.Decimal(10, 2)
  transactionRef  String?
  status          PaymentTransactionStatus
  payload         Json?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  order           orders                   @relation(fields: [orderId], references: [id])
  paymentMethod   payment_methods          @relation(fields: [paymentMethodId], references: [id])
}

model vouchers {
  id               String            @id @default(uuid()) @db.Uuid
  code             String            @unique
  description      String?
  discountType     DiscountType
  discountValue    Decimal           @db.Decimal(10, 2)
  minOrderValue    Decimal           @default(0.00) @db.Decimal(10, 2)
  maxDiscountValue Decimal?          @db.Decimal(10, 2)
  maxUses          Int?
  maxUsesPerUser   Int?
  usesCount        Int               @default(0)
  startDate        DateTime?         @db.Timestamptz(6)
  endDate          DateTime?         @db.Timestamptz(6)
  priority         Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  deletedBy        String?           @db.Uuid
  orders           orders[]
  targets          voucher_targets[]
  voucherUsages    voucher_usages[]
  voucherUsers     voucher_user[]

  @@index([deletedAt])
}

model voucher_targets {
  id         String     @id @default(uuid()) @db.Uuid
  voucherId  String     @db.Uuid
  targetType TargetType
  targetId   String?
  createdAt  DateTime   @default(now())
  voucher    vouchers   @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

model products_vector {
  productId String                 @id @db.Uuid
  content   String
  embedding Unsupported("vector")?
  updatedAt DateTime               @updatedAt
  product   products               @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model voucher_user {
  id        String   @id @default(uuid()) @db.Uuid
  voucherId String   @db.Uuid
  userId    String   @db.Uuid
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher   vouchers @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
}

model voucher_usages {
  id        String   @id @default(uuid()) @db.Uuid
  voucherId String   @db.Uuid
  userId    String   @db.Uuid
  orderId   String   @db.Uuid
  usedAt    DateTime @default(now())
  order     orders   @relation(fields: [orderId], references: [id])
  user      users    @relation(fields: [userId], references: [id])
  voucher   vouchers @relation(fields: [voucherId], references: [id])
}

model promotions {
  id               String              @id @default(uuid()) @db.Uuid
  name             String              @unique
  description      String?
  priority         Int                 @default(0)
  isActive         Boolean             @default(true)
  startDate        DateTime?           @db.Timestamptz(6)
  endDate          DateTime?           @db.Timestamptz(6)
  minOrderValue    Decimal?            @db.Decimal(12, 2)
  maxDiscountValue Decimal?            @db.Decimal(12, 2)
  usageLimit       Int?
  usedCount        Int                 @default(0)
  createdAt        DateTime            @default(now())
  deletedAt        DateTime?
  deletedBy        String?             @db.Uuid
  applyType        ApplyType           @default(EXCLUSIVE)
  stackingGroup    StackingGroup       @default(PERCENT)
  stopProcessing   Boolean             @default(false)
  rules            promotion_rules[]
  targets          promotion_targets[]

  @@index([deletedAt])
}

model promotion_rules {
  id                   String              @id @default(uuid()) @db.Uuid
  promotionId          String              @db.Uuid
  actionType           PromotionActionType
  discountValue        Decimal?            @db.Decimal(10, 2)
  buyQuantity          Int?
  getQuantity          Int?
  giftProductVariantId String?             @db.Uuid
  createdAt            DateTime            @default(now())
  promotion            promotions          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model promotion_targets {
  id          String     @id @default(uuid()) @db.Uuid
  promotionId String     @db.Uuid
  targetType  TargetType
  targetId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  targetCode  String?
  targetValue String?
  promotion   promotions @relation(fields: [promotionId], references: [id], onDelete: Cascade)
}

model blogs {
  id          String     @id @default(uuid()) @db.Uuid
  authorId    String     @db.Uuid
  title       String
  slug        String     @unique
  content     String
  imagePath   String?
  imageUrl    String?
  viewCount   Int        @default(0)
  status      BlogStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  deletedAt   DateTime?
  deletedBy   String?    @db.Uuid
  type        BlogType   @default(TIN_MOI)
  author      users      @relation(fields: [authorId], references: [id])
  comments    comments[] @relation("blogsTocomments")

  @@index([deletedAt])
}

model comments {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String?           @db.Uuid
  content    String
  targetType CommentTargetType
  targetId   String
  parentId   String?           @db.Uuid
  isApproved Boolean           @default(false)
  createdAt  DateTime          @default(now())
  deletedAt  DateTime?
  deletedBy  String?           @db.Uuid
  parent     comments?         @relation("CommentParent", fields: [parentId], references: [id])
  replies    comments[]        @relation("CommentParent")
  user       users?            @relation(fields: [userId], references: [id])
  blogs      blogs[]           @relation("blogsTocomments")

  @@index([targetType, targetId])
  @@index([deletedAt])
}

model pages {
  id          String      @id @default(uuid()) @db.Uuid
  type        PageType
  policyType  PolicyType?
  title       String
  slug        String      @unique
  content     String
  isPublished Boolean     @default(true)
  priority    Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  deletedBy   String?     @db.Uuid

  @@index([deletedAt])
}

model image_media {
  id        String        @id @default(uuid()) @db.Uuid
  type      MediaType
  position  MediaPosition
  title     String?
  imagePath String?
  imageUrl  String?
  linkUrl   String?
  order     Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  deletedBy String?       @db.Uuid
  subTitle  String?

  @@index([type, position])
  @@index([isActive])
  @@index([deletedAt])
}

model notifications {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime            @default(now())
  user      users               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model fcm_tokens {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  device    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ai_contents {
  id            String        @id @default(uuid()) @db.Uuid
  type          AiContentType
  referenceId   String?       @db.Uuid
  focusKeyword  String
  inputData     Json
  outputContent String
  seoScore      Int
  seoDetails    Json
  createdBy     String        @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([type, referenceId])
  @@index([createdBy])
  @@index([createdAt])
}

model chat_sessions {
  id         String   @id @default(uuid()) @db.Uuid
  sessionKey String   @unique
  userId    String?  @db.Uuid
  messages   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime

  user      users?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionKey])
  @@index([userId])
  @@index([expiresAt])
}

model system_settings {
  id        String          @id @default(uuid()) @db.Uuid
  group     String
  key       String
  value     String
  dataType  SettingDataType @default(STRING)
  updatedBy String?         @db.Uuid
  updatedAt DateTime        @updatedAt

  @@unique([group, key])
  @@index([group])
}

model audit_logs {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String?       @db.Uuid
  userName    String?
  userRole    String?
  action      AuditAction
  module      String
  targetId    String?
  targetType  String?
  description String
  diff        Json?
  ip          String?
  userAgent   String?
  location    String?
  severity    AuditSeverity @default(INFO)
  isSuccess   Boolean       @default(true)
  errorMsg    String?
  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([module])
  @@index([severity])
  @@index([createdAt])
  @@index([ip, createdAt])
}

model login_history {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  email      String?
  isSuccess  Boolean
  ip         String?
  userAgent  String?
  location   String?
  failReason String?
  createdAt  DateTime @default(now())
  browser    String?

  @@index([userId])
  @@index([ip, createdAt])
  @@index([createdAt])
}

model user_preferences {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model chat_memory_vectors {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   // sessionKey từ chat_sessions
  userId    String?  @db.Uuid
  content   String   @db.Text
  embedding Unsupported("vector(384)")?
  createdAt DateTime @default(now())

  user      users?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
  @@index([userId])
}

model chatbot_semantic_cache {
  id                String   @id @default(uuid()) @db.Uuid
  query             String   @db.Text
  embedding         Unsupported("vector(384)")?
  toolSignatureHash String   @db.VarChar(255)
  ttlDays           Int?
  response          Json
  hitCount          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([toolSignatureHash])

}

